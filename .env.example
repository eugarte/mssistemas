DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=mssistemas
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mssistemas

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=msseguridad

# Encryption (32 bytes hex-encoded for AES-256-GCM)
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Redis/Upstash
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOGS_DIR=./logs

# CORS
CORS_ORIGIN=*
